---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Astronomía Escolar | Proyectos Charles Darwin" description="Proyecto de astronomía escolar que acerca a los estudiantes al universo mediante observación, talleres y actividades prácticas.">
  <Navbar />
  <main class="bg-[#FCFCFC] overflow-hidden">

    <!-- HERO -->
    <section class="relative min-h-[90vh] flex items-center pt-32 pb-32 px-6 lg:px-8">
      <div class="absolute inset-0 w-full h-full z-0 overflow-hidden">
        <img src="https://images.unsplash.com/photo-1419242902214-272b3f66ee7a?q=80&w=2013&auto=format&fit=crop" alt="Astronomía Escolar" class="absolute inset-0 w-full h-full object-cover scale-105 animate-slow-zoom" />
        <div class="absolute inset-0 bg-[#09215D]/70 mix-blend-multiply"></div>
        <div class="absolute inset-0 bg-gradient-to-tr from-[#09215D]/90 via-[#09215D]/80 to-indigo-900/50"></div>
        <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-[#FCFCFC] to-transparent"></div>
      </div>
      <div class="relative z-10 w-full max-w-5xl mx-auto text-center animate-fade-in-up">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-white/20 bg-white/10 backdrop-blur-md mb-8">
          <svg class="w-4 h-4 text-indigo-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>
          <span class="trykker-small tracking-widest text-white uppercase" >Explorando el Cosmos</span>
        </div>
        <h1 class="trykker-subtitle sm:text-5xl md:text-6xl lg:text-7xl text-white mb-8 tracking-tight drop-shadow-2xl" style="text-shadow:0 10px 30px rgba(0,0,0,0.4);">Astronomía Escolar</h1>
        <p class="trykker-body text-white/90 max-w-4xl mx-auto leading-relaxed drop-shadow-md mb-8" >Lorem ipsum dolor sit amet, consectetur adipiscing elit. Praesent vehicula felis non libero dignissim, at facilisis massa elementum.</p>
      </div>
    </section>

    <!-- SECCIÓN 1 -->
    <section class="py-24 lg:py-32 max-w-7xl mx-auto px-6 lg:px-8 relative">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-24">
        <div class="w-full lg:w-1/2 reveal-on-scroll translate-y-12 opacity-0 transition-all duration-1000">
          <div class="inline-flex items-center gap-3 mb-6"><span class="w-10 h-[2px] bg-indigo-600 rounded-full"></span><span class="trykker-small uppercase tracking-widest text-indigo-700" >Ciencia y Descubrimiento</span></div>
          <h2 class="trykker-subtitle sm:text-4xl md:text-5xl text-[#09215D] mb-8 leading-tight" >Observación Astronómica</h2>
          <div class="trykker-body space-y-6 text-[#09215D]/70 leading-relaxed" >
            <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed vehicula, ligula nec sodales interdum, metus ligula vulputate arcu.</p>
            <p>Phasellus imperdiet magna a erat scelerisque, nec rhoncus massa consectetur. Vestibulum in augue elementum.</p>
          </div>
        </div>
        <div class="w-full lg:w-1/2 relative reveal-on-scroll translate-y-12 opacity-0 transition-all duration-1000 delay-200">
          <div class="relative rounded-2xl sm:rounded-[2.5rem] overflow-hidden shadow-2xl group">
            <img src="https://images.unsplash.com/photo-1462331940025-496dfbfc7564?q=80&w=2027&auto=format&fit=crop" alt="Telescopio" class="w-full h-[350px] sm:h-[500px] object-cover transform group-hover:scale-105 transition-transform duration-700" />
          </div>
          <div class="absolute -bottom-8 -left-8 bg-white p-6 rounded-3xl shadow-xl border border-indigo-50 hidden md:flex items-center gap-4 animate-bounce-slow">
            <div class="w-12 h-12 rounded-full bg-indigo-50 text-indigo-600 flex items-center justify-center flex-shrink-0"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg></div>
            <div><p class="trykker-small text-[#09215D]/50 uppercase tracking-wider mb-0.5" >Exploración</p><p class="trykker-body text-[#09215D]" >Estelar</p></div>
          </div>
        </div>
      </div>
    </section>

    <!-- SECCIÓN 2 -->
    <section class="py-24 lg:py-32 relative overflow-hidden bg-gradient-to-b from-transparent via-[#09215D]/[0.02] to-transparent">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
        <div class="flex flex-col-reverse lg:flex-row items-center gap-12 lg:gap-24">
          <div class="w-full lg:w-1/2 relative reveal-on-scroll translate-y-12 lg:translate-y-0 lg:-translate-x-12 opacity-0 transition-all duration-1000">
            <div class="relative rounded-2xl sm:rounded-[2.5rem] overflow-hidden shadow-2xl group h-[350px] sm:h-[450px] lg:h-[550px]">
              <img src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=2072&auto=format&fit=crop" alt="Planetario" class="absolute inset-0 w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" />
            </div>
          </div>
          <div class="w-full lg:w-1/2 reveal-on-scroll translate-y-12 lg:translate-y-0 lg:translate-x-12 opacity-0 transition-all duration-1000 delay-200">
            <div class="inline-flex items-center gap-3 mb-6"><span class="w-10 h-[2px] bg-indigo-600 rounded-full"></span><span class="trykker-small uppercase tracking-widest text-indigo-700" >Talleres Prácticos</span></div>
            <h2 class="trykker-subtitle sm:text-4xl md:text-5xl text-[#09215D] mb-8 leading-tight" >Club de Astronomía</h2>
            <div class="trykker-body space-y-6 text-[#09215D]/70 leading-relaxed mb-10" >
              <p>Maecenas ultrices neque ac nisl congue, et convallis ligula viverra. Integer ullamcorper purus ac scelerisque elementum.</p>
              <p>Fusce nec justo sit amet eros feugiat lobortis. Nullam eget diam lacinia, commodo risus quis, cursus felis.</p>
            </div>
            <div class="grid grid-cols-2 gap-4 sm:gap-6">
              <div class="flex items-center gap-3 sm:gap-4 group"><div class="w-10 h-10 sm:w-12 sm:h-12 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center flex-shrink-0 transition-colors duration-300 group-hover:bg-indigo-600 group-hover:text-white"><svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582" /></svg></div><span class="trykker-small sm: text-[#09215D]" >Sistema Solar</span></div>
              <div class="flex items-center gap-3 sm:gap-4 group"><div class="w-10 h-10 sm:w-12 sm:h-12 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center flex-shrink-0 transition-colors duration-300 group-hover:bg-indigo-600 group-hover:text-white"><svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg></div><span class="trykker-small sm: text-[#09215D]" >Observación Nocturna</span></div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  @keyframes fadeInUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
  .animate-fade-in-up{opacity:0;animation:fadeInUp 1s cubic-bezier(.16,1,.3,1) forwards}
  @keyframes slowZoom{0%{transform:scale(1.05)}100%{transform:scale(1.15)}}
  .animate-slow-zoom{animation:slowZoom 30s linear infinite alternate}
  @keyframes bounceSlow{0%,100%{transform:translateY(-5%)}50%{transform:none}}
  .animate-bounce-slow{animation:bounceSlow 4s infinite}
  .reveal-on-scroll.is-visible{opacity:1!important;transform:translate(0,0) scale(1)!important}
</style>
<script>
  document.addEventListener('DOMContentLoaded',()=>{const o=new IntersectionObserver(e=>{e.forEach(e=>{if(e.isIntersecting)e.target.classList.add('is-visible')})},{threshold:.15,rootMargin:"0px 0px -50px 0px"});document.querySelectorAll('.reveal-on-scroll').forEach(el=>o.observe(el))});
</script>
