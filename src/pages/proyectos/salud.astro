---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Hábitos de Vida Saludable | Proyectos Charles Darwin" description="Promovemos el bienestar integral de nuestros estudiantes, incorporando hábitos de vida saludable y actividades deportivas.">
  <Navbar />

  <main class="bg-[#FCFCFC] overflow-hidden">
    
    <!-- HERO PRINCIPAL -->
    <section class="relative min-h-[90vh] flex items-center pt-32 pb-32 px-4 sm:px-6 lg:px-8">
      <!-- Background Image & Overlays -->
      <div class="absolute inset-0 w-full h-full z-0 overflow-hidden">
        <img 
          src="https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?q=80&w=2070&auto=format&fit=crop" 
          alt="Deporte y Vida Saludable" 
          class="absolute inset-0 w-full h-full object-cover scale-105 animate-slow-zoom"
        />
        <!-- Overlay oscuro institucional -->
        <div class="absolute inset-0 bg-[#09215D]/60 mix-blend-multiply"></div>
        <!-- Gradiente temático sutil (Rojo/Rosa para Salud) -->
        <div class="absolute inset-0 bg-gradient-to-tr from-[#09215D]/90 via-[#09215D]/80 to-rose-900/40"></div>
        <!-- Gradiente de transición hacia el contenido -->
        <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-[#FCFCFC] to-transparent"></div>
      </div>

      <!-- Contenido del Hero -->
      <div class="relative z-10 w-full max-w-5xl mx-auto text-center animate-fade-in-up">
        
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-white/20 bg-white/10 backdrop-blur-md mb-8">
          <svg class="w-4 h-4 text-rose-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
          </svg>
          <span class="text-xs font-bold tracking-widest text-white uppercase" style="font-family: 'Inter', sans-serif;">Bienestar Integral</span>
        </div>

        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-8 tracking-tight drop-shadow-2xl" style="font-family: 'Poppins', sans-serif; text-shadow: 0 10px 30px rgba(0,0,0,0.4);">
          Hábitos de Vida Saludable
        </h1>
        
        <p class="text-lg md:text-xl lg:text-2xl text-white/90 max-w-4xl mx-auto leading-relaxed font-light drop-shadow-md mb-8" style="font-family: 'Inter', sans-serif;">
          Como establecimiento educacional, nos hemos preocupado de promover el bienestar integral de nuestros estudiantes, incorporando hábitos de vida saludable y fomentando la práctica regular de actividades deportivas dentro de nuestros planes y programas.
        </p>

        <p class="text-base md:text-lg text-white/70 max-w-3xl mx-auto leading-relaxed font-light" style="font-family: 'Inter', sans-serif;">
          Además, hemos generado instancias de colaboración con el Ministerio de Salud y con las redes de salud locales, con el propósito de reforzar y potenciar la formación en hábitos saludables, contribuyendo así al desarrollo físico, emocional y social de nuestros estudiantes.
        </p>

      </div>
    </section>

    <!-- SECCIÓN 1: TRABAJO CONTINUO (Split Layout) -->
    <section class="py-24 lg:py-32 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <!-- Blur decorativo fondo -->
      <div class="absolute top-1/2 left-0 w-64 h-64 bg-rose-500/5 rounded-full blur-3xl -z-10 pointer-events-none -translate-y-1/2"></div>
      
      <div class="flex flex-col lg:flex-row items-center gap-16 lg:gap-24">
        
        <!-- Textos -->
        <div class="w-full lg:w-1/2 reveal-on-scroll translate-y-12 opacity-0 transition-all duration-1000">
          <div class="inline-flex items-center gap-3 mb-6">
            <span class="w-10 h-[2px] bg-rose-600 rounded-full"></span>
            <span class="text-sm font-bold uppercase tracking-widest text-rose-700" style="font-family: 'Inter', sans-serif;">Desarrollo Físico</span>
          </div>
          <h2 class="text-4xl md:text-5xl font-bold text-[#09215D] mb-8 leading-tight" style="font-family: 'Poppins', sans-serif;">
            Hábitos de Vida Saludable
          </h2>
          <div class="space-y-6 text-lg text-[#09215D]/70 font-light leading-relaxed" style="font-family: 'Inter', sans-serif;">
            <p>
              En los últimos años, nuestro establecimiento educacional ha trabajado de manera sostenida en la promoción de hábitos de vida saludable, estableciéndolos como un eje central en todas las áreas de nuestro quehacer institucional.
            </p>
            <p>
              Este enfoque nos ha permitido no solo enfatizar la prevención del consumo de sustancias, sino también fomentar la práctica regular de actividad física, una alimentación equilibrada, adecuados hábitos de higiene y, en general, conductas que favorezcan el bienestar integral de nuestros estudiantes.
            </p>
          </div>
        </div>

        <!-- Imagen Premium -->
        <div class="w-full lg:w-1/2 relative reveal-on-scroll translate-y-12 opacity-0 transition-all duration-1000 delay-200">
          <div class="relative rounded-[2.5rem] overflow-hidden shadow-2xl shadow-[#09215D]/10 group">
            <div class="absolute inset-0 bg-[#09215D]/10 group-hover:bg-transparent transition-colors duration-500 z-10 pointer-events-none mix-blend-overlay"></div>
            <img 
              src="https://images.unsplash.com/photo-1526506114545-0d3a57fdb0e3?q=80&w=2070&auto=format&fit=crop" 
              alt="Actividad Física" 
              class="w-full h-[500px] object-cover object-center transform group-hover:scale-105 transition-transform duration-700"
            />
          </div>
          <!-- Badge flotante -->
          <div class="absolute -bottom-8 -left-8 bg-white p-6 rounded-3xl shadow-xl shadow-[#09215D]/5 border border-rose-50 hidden md:flex items-center gap-4 animate-bounce-slow">
            <div class="w-12 h-12 rounded-full bg-rose-50 text-rose-600 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-[#09215D]/50 font-bold uppercase tracking-wider mb-0.5" style="font-family: 'Inter', sans-serif;">Actividad</p>
              <p class="text-lg font-bold text-[#09215D]" style="font-family: 'Poppins', sans-serif;">Deporte y Salud</p>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- SECCIÓN 2: SENDA (Layout Invertido) -->
    <section class="py-24 lg:py-32 relative overflow-hidden bg-gradient-to-b from-transparent via-[#09215D]/[0.02] to-transparent">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="flex flex-col-reverse lg:flex-row items-center gap-16 lg:gap-24">
          
          <!-- Imagen Premium -->
          <div class="w-full lg:w-1/2 relative reveal-on-scroll -translate-x-12 opacity-0 transition-all duration-1000">
            <div class="relative rounded-[2.5rem] overflow-hidden shadow-2xl shadow-rose-900/10 group h-[550px]">
              <div class="absolute inset-0 bg-rose-900/10 group-hover:bg-transparent transition-colors duration-500 z-10 pointer-events-none mix-blend-overlay"></div>
              <img 
                src="https://images.unsplash.com/photo-1582213782179-e0d53f98f2ca?q=80&w=2070&auto=format&fit=crop" 
                alt="Colaboración en Salud" 
                class="absolute inset-0 w-full h-full object-cover object-center transform group-hover:scale-105 transition-transform duration-700"
              />
            </div>
            <!-- Elemento Dashboard Flotante -->
            <div class="absolute top-10 -right-8 bg-white/90 backdrop-blur-md p-5 rounded-2xl shadow-2xl border border-white/50 hidden lg:block">
              <div class="flex items-center gap-3 mb-2">
                <div class="w-2 h-2 rounded-full bg-rose-500 animate-pulse"></div>
                <span class="text-xs font-bold text-[#09215D] uppercase tracking-wider" style="font-family: 'Inter', sans-serif;">Red de Apoyo</span>
              </div>
              <p class="text-[#09215D]/60 text-sm font-medium" style="font-family: 'Inter', sans-serif;">Alianzas institucionales</p>
            </div>
          </div>

          <!-- Textos -->
          <div class="w-full lg:w-1/2 reveal-on-scroll translate-x-12 opacity-0 transition-all duration-1000 delay-200">
            <div class="inline-flex items-center gap-3 mb-6">
              <span class="w-10 h-[2px] bg-rose-600 rounded-full"></span>
              <span class="text-sm font-bold uppercase tracking-widest text-rose-700" style="font-family: 'Inter', sans-serif;">Alianzas Estratégicas</span>
            </div>
            <h2 class="text-4xl md:text-5xl font-bold text-[#09215D] mb-8 leading-tight" style="font-family: 'Poppins', sans-serif;">
              SENDA
            </h2>
            <div class="space-y-6 text-lg text-[#09215D]/70 font-light leading-relaxed mb-10" style="font-family: 'Inter', sans-serif;">
              <p>
                El trabajo colaborativo con otras instituciones ha sido fundamental para generar espacios de salud amigables y accesibles para nuestra comunidad educativa.
              </p>
              <p>
                En este contexto, actualmente nos encontramos trabajando en conjunto con el Programa Adolescente y el Programa Vida Sana, los cuales se han convertido en un pilar esencial dentro de nuestro compromiso con la formación integral de los estudiantes.
              </p>
              <p>
                Gracias a estas alianzas, hemos podido fortalecer la promoción de hábitos de vida saludable, prevenir riesgos asociados a la etapa escolar y adolescente, y entregar herramientas que favorezcan el bienestar físico, emocional y social de toda la comunidad.
              </p>
              <p>
                De esta manera, reafirmamos nuestra convicción de que la educación trasciende lo académico y debe incluir acciones concretas que mejoren la calidad de vida de nuestros estudiantes.
              </p>
            </div>
            
            <!-- Grid de Iconos (Dashboard vibe) -->
            <div class="grid grid-cols-2 gap-6">
              <div class="flex items-center gap-4 group">
                <div class="w-12 h-12 rounded-xl bg-rose-50 text-rose-600 flex items-center justify-center transition-colors duration-300 group-hover:bg-rose-600 group-hover:text-white">
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                  </svg>
                </div>
                <span class="text-sm font-semibold text-[#09215D]" style="font-family: 'Inter', sans-serif;">Prevención</span>
              </div>
              <div class="flex items-center gap-4 group">
                <div class="w-12 h-12 rounded-xl bg-rose-50 text-rose-600 flex items-center justify-center transition-colors duration-300 group-hover:bg-rose-600 group-hover:text-white">
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <span class="text-sm font-semibold text-[#09215D]" style="font-family: 'Inter', sans-serif;">Bienestar Emocional</span>
              </div>
            </div>

          </div>

        </div>
      </div>
    </section>

    <!-- SECCIÓN 3: PROGRAMAS LOCALES (Multimedia Showcase) -->
    <section class="py-24 lg:py-32 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16 reveal-on-scroll translate-y-12 opacity-0 transition-all duration-1000">
        <h2 class="text-4xl md:text-5xl font-bold text-[#09215D] mb-6 leading-tight" style="font-family: 'Poppins', sans-serif;">
          Programas Locales
        </h2>
        <p class="text-lg md:text-xl text-[#09215D]/70 font-light leading-relaxed mb-6" style="font-family: 'Inter', sans-serif;">
          El trabajo colaborativo con otras instituciones ha sido fundamental para generar espacios de salud amigables y accesibles para nuestra comunidad educativa.
        </p>
        <p class="text-base text-[#09215D]/60 font-light leading-relaxed" style="font-family: 'Inter', sans-serif;">
          En este contexto, actualmente nos encontramos trabajando en conjunto con el Programa Adolescente y el Programa Vida Sana, los cuales se han convertido en un pilar esencial dentro de nuestro compromiso con la formación integral de los estudiantes. Gracias a estas alianzas, hemos podido fortalecer la promoción de hábitos de vida saludable, prevenir riesgos asociados a la etapa escolar y adolescente, y entregar herramientas que favorezcan el bienestar físico, emocional y social de toda la comunidad.
        </p>
      </div>

      <!-- Contenedor Premium de Video -->
      <div class="relative reveal-on-scroll scale-95 opacity-0 transition-all duration-1000 delay-200">
        <!-- Glow detrás del video -->
        <div class="absolute inset-0 bg-gradient-to-r from-rose-400 to-[#09215D] rounded-[2.5rem] blur-2xl opacity-20 transform scale-95 translate-y-4"></div>
        
        <!-- Frame del Video -->
        <div class="relative rounded-[2.5rem] overflow-hidden shadow-2xl bg-[#09215D] aspect-video border border-white/20 group cursor-pointer">
          <!-- Placeholder de Video usando una imagen y botón de Play falso -->
          <img 
            src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?q=80&w=2020&auto=format&fit=crop" 
            alt="Video Programas Vida Sana" 
            class="w-full h-full object-cover opacity-70 group-hover:opacity-90 transition-opacity duration-700 group-hover:scale-105"
          />
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-20 h-20 md:w-24 md:h-24 bg-white/20 backdrop-blur-md rounded-full flex items-center justify-center shadow-2xl border border-white/30 group-hover:scale-110 group-hover:bg-white/30 transition-all duration-500">
              <svg class="w-8 h-8 md:w-10 md:h-10 text-white ml-2" fill="currentColor" viewBox="0 0 24 24">
                <path d="M4 2.69127C4 1.93067 4.81547 1.44851 5.48192 1.81506L22.4069 11.1238C23.0977 11.5037 23.0977 12.4963 22.4069 12.8762L5.48192 22.1849C4.81546 22.5515 4 22.0693 4 21.3087V2.69127Z" />
              </svg>
            </div>
          </div>
          <!-- Texto informativo interno -->
          <div class="absolute bottom-0 left-0 w-full p-8 bg-gradient-to-t from-[#09215D]/90 to-transparent">
            <p class="text-white font-semibold text-lg md:text-xl tracking-wide" style="font-family: 'Poppins', sans-serif;">Programa Adolescente y Vida Sana</p>
            <p class="text-white/70 text-sm md:text-base font-light" style="font-family: 'Inter', sans-serif;">Acciones concretas que mejoran la calidad de vida.</p>
          </div>
        </div>
      </div>

    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* Animación inicial del Hero */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up {
    opacity: 0;
    animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* Animación sutil de zoom en el fondo */
  @keyframes slowZoom {
    0% { transform: scale(1.05); }
    100% { transform: scale(1.15); }
  }
  .animate-slow-zoom {
    animation: slowZoom 30s linear infinite alternate;
  }

  /* Flotación para badges */
  @keyframes bounceSlow {
    0%, 100% { transform: translateY(-5%); animation-timing-function: cubic-bezier(0.8,0,1,1); }
    50% { transform: none; animation-timing-function: cubic-bezier(0,0,0.2,1); }
  }
  .animate-bounce-slow {
    animation: bounceSlow 4s infinite;
  }

  /* Estado visible para scroll */
  .reveal-on-scroll.is-visible {
    opacity: 1 !important;
    transform: translate(0, 0) scale(1) !important;
  }
</style>

<script>
  // Lógica de Scroll Reveal con IntersectionObserver
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, {
      threshold: 0.15,
      rootMargin: "0px 0px -50px 0px"
    });

    const elements = document.querySelectorAll('.reveal-on-scroll');
    elements.forEach(el => observer.observe(el));
  });
</script>
