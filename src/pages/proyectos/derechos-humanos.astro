---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Derechos Humanos | Proyectos Charles Darwin" description="Proyecto institucional de educación en Derechos Humanos, promoviendo la convivencia democrática y la justicia social.">
  <Navbar />
  <main class="bg-[#FCFCFC] overflow-hidden">
    
    <!-- HERO -->
    <section class="relative min-h-[90vh] flex items-center pt-32 pb-32 px-6 lg:px-8">
      <div class="absolute inset-0 w-full h-full z-0 overflow-hidden">
        <img src="https://images.unsplash.com/photo-1529156069898-49953e39b3ac?q=80&w=2032&auto=format&fit=crop" alt="Derechos Humanos" class="absolute inset-0 w-full h-full object-cover scale-105 animate-slow-zoom" />
        <div class="absolute inset-0 bg-[#09215D]/60 mix-blend-multiply"></div>
        <div class="absolute inset-0 bg-gradient-to-tr from-[#09215D]/90 via-[#09215D]/80 to-amber-900/40"></div>
        <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-[#FCFCFC] to-transparent"></div>
      </div>
      <div class="relative z-10 w-full max-w-5xl mx-auto text-center animate-fade-in-up">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-white/20 bg-white/10 backdrop-blur-md mb-8">
          <svg class="w-4 h-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0012 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 01-2.031.352 5.989 5.989 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 01-2.031.352 5.989 5.989 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971z" /></svg>
          <span class="trykker-small tracking-widest text-white uppercase" >Justicia y Equidad</span>
        </div>
        <h1 class="trykker-subtitle sm:text-5xl md:text-6xl lg:text-7xl text-white mb-8 tracking-tight drop-shadow-2xl" style="text-shadow:0 10px 30px rgba(0,0,0,0.4);">Derechos Humanos</h1>
        <p class="trykker-body text-white/90 max-w-4xl mx-auto leading-relaxed drop-shadow-md mb-8" >Lorem ipsum dolor sit amet, consectetur adipiscing elit. Praesent vehicula felis non libero dignissim, at facilisis massa elementum.</p>
      </div>
    </section>

    <!-- SECCIÓN 1 -->
    <section class="py-24 lg:py-32 max-w-7xl mx-auto px-6 lg:px-8 relative">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-24">
        <div class="w-full lg:w-1/2 reveal-on-scroll translate-y-12 opacity-0 transition-all duration-1000">
          <div class="inline-flex items-center gap-3 mb-6"><span class="w-10 h-[2px] bg-amber-600 rounded-full"></span><span class="trykker-small uppercase tracking-widest text-amber-700" >Formación Ciudadana</span></div>
          <h2 class="trykker-subtitle sm:text-4xl md:text-5xl text-[#09215D] mb-8 leading-tight" >Convivencia Democrática</h2>
          <div class="trykker-body space-y-6 text-[#09215D]/70 leading-relaxed" >
            <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed vehicula, ligula nec sodales interdum, metus ligula vulputate arcu.</p>
            <p>Phasellus imperdiet magna a erat scelerisque, nec rhoncus massa consectetur. Vestibulum in augue elementum.</p>
          </div>
        </div>
        <div class="w-full lg:w-1/2 relative reveal-on-scroll translate-y-12 opacity-0 transition-all duration-1000 delay-200">
          <div class="relative rounded-2xl sm:rounded-[2.5rem] overflow-hidden shadow-2xl group">
            <img src="https://images.unsplash.com/photo-1491438590914-bc09fcaaf77a?q=80&w=2070&auto=format&fit=crop" alt="Convivencia" class="w-full h-[350px] sm:h-[500px] object-cover transform group-hover:scale-105 transition-transform duration-700" />
          </div>
          <div class="absolute -bottom-8 -left-8 bg-white p-6 rounded-3xl shadow-xl border border-amber-50 hidden md:flex items-center gap-4 animate-bounce-slow">
            <div class="w-12 h-12 rounded-full bg-amber-50 text-amber-600 flex items-center justify-center flex-shrink-0"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg></div>
            <div><p class="trykker-small text-[#09215D]/50 uppercase tracking-wider mb-0.5" >Comunidad</p><p class="trykker-body text-[#09215D]" >Inclusiva</p></div>
          </div>
        </div>
      </div>
    </section>

    <!-- SECCIÓN 2 -->
    <section class="py-24 lg:py-32 relative overflow-hidden bg-gradient-to-b from-transparent via-[#09215D]/[0.02] to-transparent">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
        <div class="flex flex-col-reverse lg:flex-row items-center gap-12 lg:gap-24">
          <div class="w-full lg:w-1/2 relative reveal-on-scroll translate-y-12 lg:translate-y-0 lg:-translate-x-12 opacity-0 transition-all duration-1000">
            <div class="relative rounded-2xl sm:rounded-[2.5rem] overflow-hidden shadow-2xl group h-[350px] sm:h-[450px] lg:h-[550px]">
              <img src="https://images.unsplash.com/photo-1577896851231-70ef18881754?q=80&w=2070&auto=format&fit=crop" alt="Educación en Valores" class="absolute inset-0 w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" />
            </div>
          </div>
          <div class="w-full lg:w-1/2 reveal-on-scroll translate-y-12 lg:translate-y-0 lg:translate-x-12 opacity-0 transition-all duration-1000 delay-200">
            <div class="inline-flex items-center gap-3 mb-6"><span class="w-10 h-[2px] bg-amber-600 rounded-full"></span><span class="trykker-small uppercase tracking-widest text-amber-700" >Educación en Valores</span></div>
            <h2 class="trykker-subtitle sm:text-4xl md:text-5xl text-[#09215D] mb-8 leading-tight" >Talleres y Actividades</h2>
            <div class="trykker-body space-y-6 text-[#09215D]/70 leading-relaxed mb-10" >
              <p>Maecenas ultrices neque ac nisl congue, et convallis ligula viverra. Integer ullamcorper purus ac scelerisque elementum.</p>
              <p>Fusce nec justo sit amet eros feugiat lobortis. Nullam eget diam lacinia, commodo risus quis, cursus felis.</p>
            </div>
            <div class="grid grid-cols-2 gap-4 sm:gap-6">
              <div class="flex items-center gap-3 sm:gap-4 group"><div class="w-10 h-10 sm:w-12 sm:h-12 rounded-xl bg-amber-50 text-amber-600 flex items-center justify-center flex-shrink-0 transition-colors duration-300 group-hover:bg-amber-600 group-hover:text-white"><svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg></div><span class="trykker-small sm: text-[#09215D]" >Dignidad Humana</span></div>
              <div class="flex items-center gap-3 sm:gap-4 group"><div class="w-10 h-10 sm:w-12 sm:h-12 rounded-xl bg-amber-50 text-amber-600 flex items-center justify-center flex-shrink-0 transition-colors duration-300 group-hover:bg-amber-600 group-hover:text-white"><svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" /></svg></div><span class="trykker-small sm: text-[#09215D]" >Igualdad y Respeto</span></div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  @keyframes fadeInUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
  .animate-fade-in-up{opacity:0;animation:fadeInUp 1s cubic-bezier(.16,1,.3,1) forwards}
  @keyframes slowZoom{0%{transform:scale(1.05)}100%{transform:scale(1.15)}}
  .animate-slow-zoom{animation:slowZoom 30s linear infinite alternate}
  @keyframes bounceSlow{0%,100%{transform:translateY(-5%)}50%{transform:none}}
  .animate-bounce-slow{animation:bounceSlow 4s infinite}
  .reveal-on-scroll.is-visible{opacity:1!important;transform:translate(0,0) scale(1)!important}
</style>
<script>
  document.addEventListener('DOMContentLoaded',()=>{const o=new IntersectionObserver(e=>{e.forEach(e=>{if(e.isIntersecting)e.target.classList.add('is-visible')})},{threshold:.15,rootMargin:"0px 0px -50px 0px"});document.querySelectorAll('.reveal-on-scroll').forEach(el=>o.observe(el))});
</script>
