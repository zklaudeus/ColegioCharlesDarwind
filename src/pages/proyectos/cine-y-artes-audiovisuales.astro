---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Cine y Artes Audiovisuales | Proyectos Charles Darwin" description="Nuestro proyecto de Cine y Artes Audiovisuales busca fomentar la creatividad y el pensamiento crítico a través de la producción audiovisual.">
  <Navbar />

  <main class="bg-[#FCFCFC] overflow-hidden">
    
    <!-- HERO PRINCIPAL -->
    <section class="relative min-h-[90vh] flex items-center pt-32 pb-32 px-4 sm:px-6 lg:px-8">
      <!-- Background Image & Overlays -->
      <div class="absolute inset-0 w-full h-full z-0 overflow-hidden">
        <img 
          src="https://images.unsplash.com/photo-1485846234645-a62644f84728?q=80&w=2059&auto=format&fit=crop" 
          alt="Cine y Artes Audiovisuales" 
          class="absolute inset-0 w-full h-full object-cover scale-105 animate-slow-zoom"
        />
        <!-- Overlay oscuro institucional -->
        <div class="absolute inset-0 bg-[#09215D]/60 mix-blend-multiply"></div>
        <!-- Gradiente ecológico sutil -->
        <div class="absolute inset-0 bg-gradient-to-tr from-[#09215D]/90 via-[#09215D]/80 to-emerald-900/40"></div>
        <!-- Gradiente de transición hacia el contenido -->
        <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-[#FCFCFC] to-transparent"></div>
      </div>

      <!-- Contenido del Hero -->
      <div class="relative z-10 w-full max-w-5xl mx-auto text-center animate-fade-in-up">
        
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-white/20 bg-white/10 backdrop-blur-md mb-8">
          <svg class="w-4 h-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
          <span class="trykker-small tracking-widest text-white uppercase" >Proyecto Destacado</span>
        </div>

        <h1 class="trykker-subtitle sm:text-5xl md:text-6xl lg:text-7xl text-white mb-8 tracking-tight drop-shadow-2xl" style=" text-shadow: 0 10px 30px rgba(0,0,0,0.4);">
          Cine y Artes Audiovisuales
        </h1>
        
        <p class="trykker-body lg:text-2xl text-white/90 max-w-4xl mx-auto leading-relaxed drop-shadow-md mb-8" >
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.
        </p>

        <p class="trykker-body md: text-white/70 max-w-3xl mx-auto leading-relaxed" >
          Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum.
        </p>

      </div>
    </section>

    <!-- SECCIÓN 1: TRABAJO CONTINUO (Split Layout) -->
    <section class="py-24 lg:py-32 max-w-7xl mx-auto px-6 sm:px-6 lg:px-8 relative">
      <!-- Blur decorativo fondo -->
      <div class="absolute top-1/2 left-0 w-64 h-64 bg-emerald-500/5 rounded-full blur-3xl -z-10 pointer-events-none -translate-y-1/2"></div>
      
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-24">
        
        <!-- Textos -->
        <div class="w-full lg:w-1/2 reveal-on-scroll translate-y-12 opacity-0 transition-all duration-1000">
          <div class="inline-flex items-center gap-3 mb-6">
            <span class="w-10 h-[2px] bg-emerald-600 rounded-full"></span>
            <span class="trykker-small uppercase tracking-widest text-emerald-700" >Desarrollo Creativo</span>
          </div>
          <h2 class="trykker-subtitle sm:text-4xl md:text-5xl text-[#09215D] mb-8 leading-tight" >
            Expresión y Técnica
          </h2>
          <div class="trykker-body space-y-6 text-[#09215D]/70 leading-relaxed" >
            <p>
              Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nullam in venenatis enim. Sed vehicula, ligula nec sodales interdum, metus ligula vulputate arcu, sit amet tincidunt justo nulla eget sapien.
            </p>
            <p>
              Phasellus imperdiet magna a erat scelerisque, nec rhoncus massa consectetur. Vestibulum in augue elementum, laoreet dolor in, interdum lectus. Curabitur vel risus nec nulla auctor luctus vel sit amet turpis.
            </p>
          </div>
        </div>

        <!-- Imagen Premium -->
        <div class="w-full lg:w-1/2 relative reveal-on-scroll translate-y-12 opacity-0 transition-all duration-1000 delay-200">
          <div class="relative rounded-2xl sm:rounded-[2.5rem] overflow-hidden shadow-2xl shadow-[#09215D]/10 group">
            <div class="absolute inset-0 bg-[#09215D]/10 group-hover:bg-transparent transition-colors duration-500 z-10 pointer-events-none mix-blend-overlay"></div>
            <img 
              src="https://images.unsplash.com/photo-1594908900066-3f47337549d8?q=80&w=2070&auto=format&fit=crop" 
              alt="Producción Audiovisual" 
              class="w-full h-[350px] sm:h-[500px] object-cover object-center transform group-hover:scale-105 transition-transform duration-700"
            />
          </div>
          <!-- Badge flotante -->
          <div class="absolute -bottom-8 -left-8 bg-white p-6 rounded-3xl shadow-xl shadow-[#09215D]/5 border border-emerald-50 hidden md:flex items-center gap-4 animate-bounce-slow">
            <div class="w-12 h-12 rounded-full bg-emerald-50 text-emerald-600 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
              </svg>
            </div>
            <div>
              <p class="trykker-small text-[#09215D]/50 uppercase tracking-wider mb-0.5" >Talento</p>
              <p class="trykker-body text-[#09215D]" >Audiovisual</p>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- SECCIÓN 2: CENTRO DE RECICLAJE (Layout Invertido) -->
    <section class="py-24 lg:py-32 relative overflow-hidden bg-gradient-to-b from-transparent via-[#09215D]/[0.02] to-transparent">
      <div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8 relative z-10">
        <div class="flex flex-col-reverse lg:flex-row items-center gap-12 lg:gap-24">
          
          <!-- Imagen Premium -->
          <div class="w-full lg:w-1/2 relative reveal-on-scroll translate-y-12 lg:translate-y-0 lg:-translate-x-12 opacity-0 transition-all duration-1000">
            <div class="relative rounded-2xl sm:rounded-[2.5rem] overflow-hidden shadow-2xl shadow-emerald-900/10 group h-[350px] sm:h-[450px] lg:h-[550px]">
              <div class="absolute inset-0 bg-emerald-900/10 group-hover:bg-transparent transition-colors duration-500 z-10 pointer-events-none mix-blend-overlay"></div>
              <img 
                src="https://images.unsplash.com/photo-1440404653325-ab127d49abc1?q=80&w=2070&auto=format&fit=crop" 
                alt="Talleres de Cine" 
                class="absolute inset-0 w-full h-full object-cover object-center transform group-hover:scale-105 transition-transform duration-700"
              />
            </div>
            <!-- Elemento Dashboard Flotante -->
            <div class="absolute top-10 -right-8 bg-white/90 backdrop-blur-md p-5 rounded-2xl shadow-2xl border border-white/50 hidden lg:block">
              <div class="flex items-center gap-3 mb-2">
                <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
                <span class="trykker-small text-[#09215D] uppercase tracking-wider" >En Vivo</span>
              </div>
              <p class="trykker-small text-[#09215D]/60" >Producciones Estudiantiles</p>
            </div>
          </div>

          <!-- Textos -->
          <div class="w-full lg:w-1/2 reveal-on-scroll translate-y-12 lg:translate-y-0 lg:translate-x-12 opacity-0 transition-all duration-1000 delay-200">
            <div class="inline-flex items-center gap-3 mb-6">
              <span class="w-10 h-[2px] bg-emerald-600 rounded-full"></span>
              <span class="trykker-small uppercase tracking-widest text-emerald-700" >Nuevas Narrativas</span>
            </div>
            <h2 class="trykker-subtitle sm:text-4xl md:text-5xl text-[#09215D] mb-8 leading-tight" >
              Talleres y Producción
            </h2>
            <div class="trykker-body space-y-6 text-[#09215D]/70 leading-relaxed mb-10" >
              <p>
                Maecenas ultrices neque ac nisl congue, et convallis ligula viverra. Integer ullamcorper purus ac scelerisque elementum. Etiam vel ante condimentum, vehicula nisi nec, interdum magna.
              </p>
              <p>
                Fusce nec justo sit amet eros feugiat lobortis. Nullam eget diam lacinia, commodo risus quis, cursus felis. Sed sit amet tincidunt arcu. Morbi efficitur tristique justo, non commodo diam sagittis eu.
              </p>
            </div>
            
            <!-- Grid de Iconos Ecológicos (Dashboard vibe) -->
            <div class="grid grid-cols-2 gap-4 sm:gap-6">
              <div class="flex items-center gap-3 sm:gap-4 group">
                <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center flex-shrink-0 transition-colors duration-300 group-hover:bg-emerald-600 group-hover:text-white">
                  <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z" />
                  </svg>
                </div>
                <span class="trykker-small sm: text-[#09215D]" >Cine Documental</span>
              </div>
              <div class="flex items-center gap-3 sm:gap-4 group">
                <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center flex-shrink-0 transition-colors duration-300 group-hover:bg-emerald-600 group-hover:text-white">
                  <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                  </svg>
                </div>
                <span class="trykker-small sm: text-[#09215D]" >Ficción y Cortos</span>
              </div>
            </div>

          </div>

        </div>
      </div>
    </section>

    <!-- SECCIÓN 3: HUERTA COMUNITARIA (Multimedia Showcase) -->
    <section class="py-24 lg:py-32 max-w-6xl mx-auto px-6 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16 reveal-on-scroll translate-y-12 opacity-0 transition-all duration-1000">
        <h2 class="trykker-title text-[#09215D] mb-6 leading-tight" >
          Festival Audiovisual
        </h2>
        <p class="trykker-body text-[#09215D]/70 leading-relaxed" >
          Aenean auctor elit non odio dignissim, vitae consequat metus congue. Aliquam erat volutpat. Praesent id arcu id massa cursus scelerisque. Vivamus quis magna neque.
        </p>
      </div>

      <!-- Contenedor Premium de Video -->
      <div class="relative reveal-on-scroll scale-95 opacity-0 transition-all duration-1000 delay-200">
        <!-- Glow detrás del video -->
        <div class="absolute inset-0 bg-gradient-to-r from-emerald-400 to-[#09215D] rounded-[2.5rem] blur-2xl opacity-20 transform scale-95 translate-y-4"></div>
        
        <!-- Frame del Video -->
        <div class="relative rounded-[2.5rem] overflow-hidden shadow-2xl bg-[#09215D] aspect-video border border-white/20 group cursor-pointer">
          <!-- Placeholder de Video usando una imagen y botón de Play falso -->
          <img 
            src="https://images.unsplash.com/photo-1606569352726-0e1d09618037?q=80&w=2070&auto=format&fit=crop" 
            alt="Festival de Cine" 
            class="w-full h-full object-cover opacity-70 group-hover:opacity-90 transition-opacity duration-700 group-hover:scale-105"
          />
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-20 h-20 md:w-24 md:h-24 bg-white/20 backdrop-blur-md rounded-full flex items-center justify-center shadow-2xl border border-white/30 group-hover:scale-110 group-hover:bg-white/30 transition-all duration-500">
              <svg class="w-8 h-8 md:w-10 md:h-10 text-white ml-2" fill="currentColor" viewBox="0 0 24 24">
                <path d="M4 2.69127C4 1.93067 4.81547 1.44851 5.48192 1.81506L22.4069 11.1238C23.0977 11.5037 23.0977 12.4963 22.4069 12.8762L5.48192 22.1849C4.81546 22.5515 4 22.0693 4 21.3087V2.69127Z" />
              </svg>
            </div>
          </div>
          <!-- Texto informativo interno -->
          <div class="absolute bottom-0 left-0 w-full p-8 bg-gradient-to-t from-[#09215D]/90 to-transparent">
            <p class="trykker-body text-white tracking-wide" >Festival Escolar de Cortometrajes</p>
            <p class="trykker-small text-white/70 md:text-base" >Conoce los proyectos destacados de nuestros estudiantes.</p>
          </div>
        </div>
      </div>

    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* Animación inicial del Hero */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up {
    opacity: 0;
    animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* Animación sutil de zoom en el fondo */
  @keyframes slowZoom {
    0% { transform: scale(1.05); }
    100% { transform: scale(1.15); }
  }
  .animate-slow-zoom {
    animation: slowZoom 30s linear infinite alternate;
  }

  /* Flotación para badges */
  @keyframes bounceSlow {
    0%, 100% { transform: translateY(-5%); animation-timing-function: cubic-bezier(0.8,0,1,1); }
    50% { transform: none; animation-timing-function: cubic-bezier(0,0,0.2,1); }
  }
  .animate-bounce-slow {
    animation: bounceSlow 4s infinite;
  }

  /* Estado visible para scroll */
  .reveal-on-scroll.is-visible {
    opacity: 1 !important;
    transform: translate(0, 0) scale(1) !important;
  }
</style>

<script>
  // Lógica de Scroll Reveal con IntersectionObserver
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          // Opcional: Descomentar la siguiente línea si quieres que la animación ocurra solo 1 vez
          // observer.unobserve(entry.target); 
        }
      });
    }, {
      threshold: 0.15, // Activar cuando el 15% del elemento sea visible
      rootMargin: "0px 0px -50px 0px"
    });

    const elements = document.querySelectorAll('.reveal-on-scroll');
    elements.forEach(el => observer.observe(el));
  });
</script>
