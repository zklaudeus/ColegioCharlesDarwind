---

<Layout title="Comunidad Escolar | Colegio Charles Darwin" description="Conoce a los profesionales que forman parte de nuestra comunidad educativa, comprometidos con la formación y acompañamiento de nuestros estudiantes.">
  <Navbar />

  <main class="bg-[#FCFCFC] pt-32 pb-24 min-h-screen">
    
    <!-- SECCIÓN INTRODUCTORIA -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-16 text-center">
      <div class="inline-flex items-center gap-3 mb-4">
        <span class="w-8 h-[1px] bg-[#C90203]"></span>
        <span class="trykker-small uppercase tracking-[0.2em] text-[#C90203]" >Colegio Charles Darwin</span>
        <span class="w-8 h-[1px] bg-[#C90203]"></span>
      </div>
      <h1 class="trykker-title text-[#09215D] mb-6 tracking-tight" >
        Nuestro Equipo
      </h1>
      <p class="trykker-body text-[#09215D]/70 max-w-3xl mx-auto leading-relaxed" >
        Conoce a los profesionales que forman parte de nuestra comunidad educativa, comprometidos con la formación, acompañamiento e inclusión de nuestros estudiantes.
      </p>
    </section>

    <!-- SISTEMA DE FILTROS -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
      <div class="flex flex-wrap items-center justify-center gap-3" id="filters-container">
        {categoriasFiltro.map((cat, index) => (
          <button 
            class={`filter-btn px-6 py-2.5 rounded-full text-sm font-semibold transition-all duration-300 border ${index === 0 ? 'bg-[#09215D] text-white border-[#09215D] shadow-md' : 'bg-white text-[#09215D]/70 border-[#09215D]/10 hover:border-[#09215D]/30 hover:bg-[#09215D]/5'}`}
            data-target={cat}
            
          >
            {cat}
          </button>
        ))}
      </div>
    </section>

    <!-- GRILLA DE TARJETAS (4 columnas) -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8" id="community-grid">
        {comunidad.map(persona => (
          <div 
            class="community-card bg-white rounded-[2rem] shadow-lg shadow-[#09215D]/5 border border-[#09215D]/10 overflow-hidden group hover:-translate-y-2 transition-all duration-500"
            data-category={persona.categoria}
          >
            <!-- Cabecera de color Institucional -->
            <div class="bg-gradient-to-br from-[#09215D] to-[#1a3885] pt-8 pb-6 px-6 relative overflow-hidden flex flex-col items-center text-center">
              <!-- Elementos decorativos (luces y círculos) -->
              <div class="absolute -bottom-6 -right-6 w-24 h-24 bg-white/10 rounded-full opacity-30 blur-xl"></div>
              <div class="absolute top-0 left-0 w-32 h-32 bg-[#C90203]/20 rounded-full opacity-20 blur-2xl -translate-x-1/2 -translate-y-1/2"></div>

              <!-- Avatar -->
              <div class="w-24 h-24 rounded-full bg-white overflow-hidden mb-4 ring-4 ring-white/20 shadow-xl flex-shrink-0 relative z-10 flex items-center justify-center">
                {persona.foto
                  ? <img
                      src={persona.foto}
                      alt={persona.nombre}
                      class="w-full h-full object-cover object-top"
                    />
                  : <span class="trykker-subtitle text-[#09215D]/50">{persona.nombre.charAt(0)}</span>
                }
              </div>

              <h4 class="trykker-body text-white leading-tight mb-2 relative z-10" >{persona.nombre}</h4>
              <span class="inline-block bg-white/10 text-white text-[10px] font-semibold px-3 py-1.5 rounded-full border border-white/20 tracking-wider uppercase relative z-10" >
                {persona.cargo}
              </span>
            </div>

            <!-- Contenido compacto -->
            <div class="p-6 space-y-4">
              
              <!-- Área / Especialidad -->
              <div class="flex items-start gap-3 group/item">
                <div class="w-8 h-8 rounded-lg bg-[#09215D]/5 text-[#09215D] flex items-center justify-center flex-shrink-0 group-hover/item:bg-[#09215D] group-hover/item:text-white transition-colors duration-300">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                  </svg>
                </div>
                <div>
                  <p class="text-[10px] font-sans text-[#09215D]/50 uppercase tracking-widest mb-0.5 font-semibold">Área / Especialidad</p>
                  <p class="trykker-small text-[#09215D] leading-snug">{persona.area}</p>
                </div>
              </div>

              <!-- Descripción Breve -->
              <div class="flex items-start gap-3 group/item pt-2 border-t border-[#09215D]/5">
                <div class="w-8 h-8 rounded-lg bg-[#09215D]/5 text-[#09215D] flex items-center justify-center flex-shrink-0 group-hover/item:bg-[#09215D] group-hover/item:text-white transition-colors duration-300">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-[10px] font-sans text-[#09215D]/50 uppercase tracking-widest mb-0.5 font-semibold">Perfil</p>
                  <p class="trykker-small text-[#09215D]/80 leading-relaxed" >{persona.descripcion}</p>
                </div>
              </div>

            </div>
          </div>
        ))}
      </div>

      <!-- Mensaje cuando no hay resultados en el filtro -->
      <div id="no-results-msg" class="hidden text-center py-12">
        <p class="trykker-body text-[#09215D]/50" >No se encontraron miembros en esta categoría.</p>
      </div>
    </section>

  </main>
  
  <Footer />
</Layout>

<script>
  // Lógica de Filtrado en Cliente (Vanilla JS)
  document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.community-card');
    const noResultsMsg = document.getElementById('no-results-msg');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        // 1. Actualizar estilos de los botones
        filterBtns.forEach(b => {
          b.classList.remove('bg-[#09215D]', 'text-white', 'border-[#09215D]', 'shadow-md');
          b.classList.add('bg-white', 'text-[#09215D]/70', 'border-[#09215D]/10', 'hover:border-[#09215D]/30', 'hover:bg-[#09215D]/5');
        });
        btn.classList.remove('bg-white', 'text-[#09215D]/70', 'border-[#09215D]/10', 'hover:border-[#09215D]/30', 'hover:bg-[#09215D]/5');
        btn.classList.add('bg-[#09215D]', 'text-white', 'border-[#09215D]', 'shadow-md');

        // 2. Filtrar las tarjetas
        const targetCategory = btn.getAttribute('data-target');
        let visibleCount = 0;

        cards.forEach(card => {
          const cardCategory = card.getAttribute('data-category');
          
          if (targetCategory === 'Todos' || cardCategory === targetCategory) {
            card.style.display = 'block';
            // Pequeña animación al mostrar
            card.animate([
              { opacity: 0, transform: 'scale(0.95)' },
              { opacity: 1, transform: 'scale(1)' }
            ], {
              duration: 300,
              easing: 'ease-out'
            });
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });

        // 3. Mostrar mensaje si no hay resultados
        if (noResultsMsg) {
          if (visibleCount === 0) {
            noResultsMsg.classList.remove('hidden');
          } else {
            noResultsMsg.classList.add('hidden');
          }
        }
      });
    });
  });
</script>