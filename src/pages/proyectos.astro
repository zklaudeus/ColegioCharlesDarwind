---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

// Datos de los proyectos
const proyectos = [
  {
    id: 'medio-ambiente',
    titulo: "Medio Ambiente",
    descripcion: "Iniciativas ecológicas enfocadas en el reciclaje, sustentabilidad y cuidado de nuestro entorno natural y escolar.",
    slug: "/proyectos/medio-ambiente",
    icono: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" /></svg>`,
    color: "from-emerald-500 to-teal-700"
  },
  {
    id: 'cine',
    titulo: "Cine y Artes Audiovisuales",
    descripcion: "Taller de apreciación y creación audiovisual para desarrollar la expresión creativa y el pensamiento crítico.",
    slug: "/proyectos/cine-y-artes-audiovisuales",
    icono: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.375 19.5h17.25m-17.25 0a1.125 1.125 0 01-1.125-1.125M3.375 19.5h7.5c.621 0 1.125-.504 1.125-1.125m-9.75 0V5.625m0 12.75v-1.5c0-.621.504-1.125 1.125-1.125m18.375 2.625V5.625m0 12.75c0 .621-.504 1.125-1.125 1.125m1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125m0 3.75h-7.5A1.125 1.125 0 0112 18.375m9.75-12.75c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125m19.5 0v1.5c0 .621-.504 1.125-1.125 1.125M2.25 5.625v1.5c0 .621.504 1.125 1.125 1.125m0 0h17.25m-17.25 0h7.5c.621 0 1.125.504 1.125 1.125M3.375 8.25c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125m17.25-3.75h-7.5c-.621 0-1.125.504-1.125 1.125m8.625-1.125c.621 0 1.125.504 1.125 1.125v1.5c0 .621-.504 1.125-1.125 1.125m-17.25 0h7.5m-7.5 0c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125M12 10.875v-1.5m0 1.5c0 .621-.504 1.125-1.125 1.125M12 10.875c0 .621.504 1.125 1.125 1.125m-2.25 0c.621 0 1.125.504 1.125 1.125M13.125 12h7.5m-7.5 0c-.621 0-1.125.504-1.125 1.125M20.625 12c.621 0 1.125.504 1.125 1.125v1.5c0 .621-.504 1.125-1.125 1.125m-17.25 0h7.5m-7.5 0c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125M12 16.5v-1.5m0 1.5c0 .621-.504 1.125-1.125 1.125M12 16.5c0 .621.504 1.125 1.125 1.125m-2.25 0c.621 0 1.125.504 1.125 1.125m4.5 0c.621 0 1.125.504 1.125 1.125M12 20.625v-1.5" /></svg>`,
    color: "from-purple-500 to-indigo-700"
  },
  {
    id: 'salud',
    titulo: "Salud y Bienestar",
    descripcion: "Fomento de hábitos de vida saludable, nutrición consciente y cuidado integral físico y emocional.",
    slug: "/proyectos/salud",
    icono: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" /></svg>`,
    color: "from-rose-500 to-red-700"
  },
  {
    id: 'ingles',
    titulo: "Inglés Institucional",
    descripcion: "Inmersión lingüística y certificación internacional para preparar a nuestros estudiantes para un mundo globalizado.",
    slug: "/proyectos/ingles",
    icono: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 21l5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 016-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 01-3.827-5.802" /></svg>`,
    color: "from-blue-500 to-[#09215D]"
  },
  {
    id: 'derechos-humanos',
    titulo: "Derechos Humanos",
    descripcion: "Formación en valores cívicos, respeto, memoria e inclusión para construir una sociedad más justa.",
    slug: "/proyectos/derechos-humanos",
    icono: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" /></svg>`,
    color: "from-amber-500 to-orange-700"
  },
  {
    id: 'astronomia',
    titulo: "Astronomía Escolar",
    descripcion: "Exploración del cosmos e incentivo del pensamiento científico mediante la observación e investigación del universo.",
    slug: "/proyectos/astronomia",
    icono: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M9 9.563C9 9.252 9.252 9 9.563 9h4.874c.311 0 .563.252.563.563v4.874c0 .311-.252.563-.563.563H9.564A.562.562 0 019 14.437V9.564z" /></svg>`,
    color: "from-slate-700 to-black"
  }
];
---

<Layout title="Proyectos | Colegio Charles Darwin" description="Conoce las diversas áreas y proyectos que buscan fortalecer el desarrollo integral de nuestros estudiantes en el Colegio Charles Darwin.">
  <Navbar />

  <main class="bg-[#FCFCFC] pt-32 pb-24 min-h-screen overflow-hidden">
    
    <!-- SECCIÓN INTRODUCTORIA (HERO) -->
    <section class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center mb-24">
      <!-- Elementos Decorativos de Fondo -->
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-3xl h-64 bg-gradient-to-b from-[#09215D]/5 to-transparent rounded-full blur-3xl -z-10 pointer-events-none"></div>
      <div class="absolute -top-10 left-1/4 w-32 h-32 bg-[#C90203]/10 rounded-full blur-2xl -z-10 pointer-events-none"></div>
      <div class="absolute top-20 right-1/4 w-48 h-48 bg-[#09215D]/10 rounded-full blur-3xl -z-10 pointer-events-none"></div>

      <!-- Contenido Hero -->
      <div class="inline-flex items-center gap-3 mb-6 animate-fade-in-up">
        <span class="w-8 h-[1px] bg-[#C90203]"></span>
        <span class="trykker-small uppercase tracking-[0.2em] text-[#C90203]" >Áreas de Desarrollo</span>
        <span class="w-8 h-[1px] bg-[#C90203]"></span>
      </div>
      
      <h1 class="trykker-title lg:text-7xl text-[#09215D] mb-8 tracking-tight animate-fade-in-up" style=" animation-delay: 100ms;">
        Proyectos
      </h1>
      
      <p class="trykker-body text-[#09215D]/70 max-w-4xl mx-auto leading-relaxed animate-fade-in-up" style=" animation-delay: 200ms;">
        En la actualidad, como establecimiento educacional, nos encontramos trabajando en diversas áreas que buscan fortalecer el desarrollo integral de nuestros estudiantes. Entendemos que la formación escolar no se limita únicamente a los aprendizajes académicos, sino que debe abarcar también aspectos socioemocionales, culturales, deportivos y ambientales, que contribuyan a la construcción de personas íntegras, responsables y comprometidas con su entorno.
      </p>
    </section>

    <!-- GRILLA DE PROYECTOS -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 xl:gap-10">
        
        {proyectos.map((proyecto, index) => (
          <div class="group relative flex flex-col bg-white rounded-[2rem] shadow-xl shadow-[#09215D]/5 border border-[#09215D]/10 overflow-hidden hover:-translate-y-2 hover:shadow-2xl hover:shadow-[#09215D]/10 transition-all duration-500 animate-fade-in-up" style={`animation-delay: ${300 + (index * 100)}ms;`}>
            
            <!-- Decoración Superior (Luz de Color) -->
            <div class="absolute top-0 left-0 w-full h-1/2 bg-gradient-to-br opacity-5 group-hover:opacity-10 transition-opacity duration-500 pointer-events-none rounded-t-[2rem]"></div>
            
            <div class="p-8 sm:p-10 flex-1 flex flex-col">
              
              <!-- Ícono -->
              <div class="mb-8 relative">
                <!-- Glow del icono -->
                <div class={`absolute inset-0 bg-gradient-to-br ${proyecto.color} blur-xl opacity-20 group-hover:opacity-40 transition-opacity duration-500 rounded-full scale-150`}></div>
                
                <div class={`relative w-16 h-16 rounded-2xl bg-gradient-to-br ${proyecto.color} flex items-center justify-center text-white shadow-lg transform group-hover:scale-110 group-hover:rotate-3 transition-transform duration-500`}>
                  <Fragment set:html={proyecto.icono} />
                </div>
              </div>

              <!-- Textos -->
              <h3 class="trykker-subtitle text-[#09215D] mb-4 group-hover:text-[#C90203] transition-colors duration-300" >
                {proyecto.titulo}
              </h3>
              
              <p class="text-[15px] text-[#09215D]/70 leading-relaxed flex-1 font-light" >
                {proyecto.descripcion}
              </p>

              <!-- Botón Animado (Conocer Proyecto) -->
              <div class="mt-10">
                <a href={proyecto.slug} class="trykker-small inline-flex items-center gap-3 text-[#09215D] group/btn" >
                  <span class="relative">
                    Conocer Proyecto
                    <span class="absolute left-0 -bottom-1 w-0 h-0.5 bg-[#C90203] transition-all duration-300 group-hover/btn:w-full"></span>
                  </span>
                  <div class="w-8 h-8 rounded-full bg-[#09215D]/5 flex items-center justify-center text-[#09215D] group-hover/btn:bg-[#C90203] group-hover/btn:text-white transition-colors duration-300">
                    <svg class="w-4 h-4 transform group-hover/btn:translate-x-0.5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                  </div>
                </a>
              </div>

            </div>
          </div>
        ))}
        
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* Animación de entrada suave (Fade In Up) */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in-up {
    opacity: 0;
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
