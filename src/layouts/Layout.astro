---
interface Props {
  title?: string;
  description?: string;
}

import '../styles/global.css';

const {
  title = "Colegio Charles Darwin",
  description = "Colegio Charles Darwin — Formando líderes del futuro con excelencia académica, valores y compromiso social.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />

    <!-- SEO -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <!-- Fuentes premium -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@400;500;600;700&family=Trykker&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    min-height: 100%;
    scroll-behavior: smooth;
    font-family: 'Inter', system-ui, sans-serif;
    background-color: #fcfcfc;
    color: #09215D;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ══════════════════════════════════════════════ */
  /* TIPOGRAFÍA TRYKKER — Clases utilitarias       */
  /* ══════════════════════════════════════════════ */

  /* Base Trykker */
  .trykker {
    font-family: 'Trykker', serif;
    font-weight: 400;
    font-style: normal;
  }

  /* ── Títulos principales (Hero, H1) ── */
  .trykker-hero {
    font-family: 'Trykker', serif;
    font-weight: 400;
    font-size: 2rem;          /* 32px mobile */
    line-height: 1.15;
    letter-spacing: -0.01em;
  }
  @media (min-width: 640px)  { .trykker-hero { font-size: 3rem; } }      /* 48px */
  @media (min-width: 768px)  { .trykker-hero { font-size: 3.75rem; } }   /* 60px */
  @media (min-width: 1024px) { .trykker-hero { font-size: 4.5rem; } }    /* 72px */

  /* ── Títulos de sección (H2) ── */
  .trykker-title {
    font-family: 'Trykker', serif;
    font-weight: 400;
    font-size: 1.75rem;       /* 28px mobile */
    line-height: 1.2;
    letter-spacing: -0.005em;
  }
  @media (min-width: 640px)  { .trykker-title { font-size: 2.25rem; } }  /* 36px */
  @media (min-width: 768px)  { .trykker-title { font-size: 3rem; } }     /* 48px */

  /* ── Subtítulos (H3, sección secundaria) ── */
  .trykker-subtitle {
    font-family: 'Trykker', serif;
    font-weight: 400;
    font-size: 1.25rem;       /* 20px mobile */
    line-height: 1.3;
  }
  @media (min-width: 640px)  { .trykker-subtitle { font-size: 1.5rem; } }  /* 24px */
  @media (min-width: 768px)  { .trykker-subtitle { font-size: 1.75rem; } } /* 28px */

  /* ── Texto cuerpo (párrafos, descripciones) ── */
  .trykker-body {
    font-family: 'Trykker', serif;
    font-weight: 400;
    font-size: 1rem;          /* 16px mobile */
    line-height: 1.75;
  }
  @media (min-width: 640px)  { .trykker-body { font-size: 1.125rem; } }  /* 18px */

  /* ── Texto pequeño (badges, labels, captions) ── */
  .trykker-small {
    font-family: 'Trykker', serif;
    font-weight: 400;
    font-size: 0.875rem;      /* 14px */
    line-height: 1.5;
  }
</style>
