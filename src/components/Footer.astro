---
// Footer.astro — Footer institucional premium
const currentYear = new Date().getFullYear();
const currentPath = Astro.url.pathname;
---

<footer class="bg-[#09215D] pt-24 pb-10 text-white relative overflow-hidden">
  <!-- Elemento decorativo sutil en el fondo -->
  <div
    class="absolute top-0 right-0 w-[600px] h-[600px] bg-white opacity-[0.02] rounded-full blur-[100px] pointer-events-none transform translate-x-1/2 -translate-y-1/2"
  >
  </div>
  <div
    class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-[#C90203] opacity-[0.03] rounded-full blur-[80px] pointer-events-none transform -translate-x-1/2 translate-y-1/2"
  >
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
    <!-- ══════════════════════════════════════════════════ -->
    <!-- CONTENEDOR PRINCIPAL: 4 COLUMNAS EN DESKTOP        -->
    <!-- ══════════════════════════════════════════════════ -->
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8 mb-20 text-center md:text-left"
    >
      <!-- ─── SECCIÓN 1: IDENTIDAD ─────────────────────── -->
      <div class="lg:col-span-4 flex flex-col items-center md:items-start">
        <!-- Logo y Nombre -->
        <div class="flex items-center gap-4 mb-6 group cursor-pointer">
          <div
            class="w-16 h-16 lg:w-20 lg:h-20 flex items-center justify-center transition-transform duration-300 group-hover:scale-105"
          >
            <img
              src="/logo.png"
              alt="Logo Colegio Charles Darwin"
              class="w-full h-full object-contain drop-shadow-lg"
            />
          </div>
          <div class="leading-tight text-left">
            <p class="trykker-small tracking-[0.15em] uppercase text-red-500">
              Colegio
            </p>
            <h2
              class="trykker-subtitle tracking-tight text-white leading-tight"
            >
              Charles Darwin <br class="hidden lg:block" /><span
                class="trykker-small opacity-90">de Ancud</span
              >
            </h2>
          </div>
        </div>

        <p
          class="trykker-body leading-relaxed max-w-sm"
          style="color: rgba(252,252,252,0.7);"
        >
          Comprometidos con la formación integral, el desarrollo humano y la
          excelencia educativa.
        </p>
      </div>

      <!-- ─── SECCIÓN 2: NAVEGACIÓN ────────────────────── -->
      <div
        class="lg:col-span-2 lg:col-start-6 flex flex-col items-center md:items-start"
      >
        <h3 class="trykker-subtitle mb-6 tracking-wide" style="color: #FCFCFC;">
          Navegación
        </h3>
        <ul
          class="trykker-body flex flex-col gap-4 items-center md:items-start"
        >
          {
            [
              { name: "Inicio", href: "/" },
              { name: "Nosotros", href: "/nosotros" },
              { name: "Comunidad", href: "/comunidad" },
              { name: "Proyectos", href: "/proyectos" },
              { name: "Protocolos", href: "/protocolos" },
              { name: "Contacto", href: "/contacto" },
            ].map((item) => {
              const isActive =
                currentPath === item.href ||
                (item.href !== "/" && currentPath.startsWith(item.href));
              return (
                <li>
                  <a
                    href={item.href}
                    class={`group flex items-center gap-2 text-sm transition-colors duration-300 ${isActive ? "text-white font-medium" : "text-white/70 hover:text-white"}`}
                  >
                    <span
                      class={`w-1.5 h-1.5 rounded-full bg-[#C90203] transition-all duration-300 ${isActive ? "opacity-100 ml-0" : "opacity-0 -ml-3 group-hover:opacity-100 group-hover:ml-0"}`}
                    />
                    <span
                      class={`transition-transform duration-300 ${isActive ? "translate-x-1" : "group-hover:translate-x-1"}`}
                    >
                      {item.name}
                    </span>
                  </a>
                </li>
              );
            })
          }
        </ul>
      </div>

      <!-- ─── SECCIÓN 3: CONTACTO ──────────────────────── -->
      <div class="lg:col-span-3 flex flex-col items-center md:items-start">
        <h3 class="trykker-subtitle mb-6 tracking-wide" style="color: #FCFCFC;">
          Contacto
        </h3>
        <ul
          class="trykker-small flex flex-col gap-5 items-center md:items-start"
          style="color: rgba(252,252,252,0.7);"
        >
          <!-- Dirección -->
          <li class="flex items-start gap-3 group">
            <svg
              class="w-5 h-5 mt-0.5 text-[#C90203] opacity-80 group-hover:opacity-100 transition-opacity flex-shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
              ></path>
            </svg>
            <span
              class="text-left group-hover:text-white transition-colors duration-300 cursor-default"
            >
              Jose Mucke 224<br />Ancud, Chile
            </span>
          </li>

          <!-- Teléfono -->
          <li class="flex items-start gap-3 group">
            <svg
              class="w-5 h-5 mt-0.5 text-[#C90203] opacity-80 group-hover:opacity-100 transition-opacity flex-shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.896-1.596-5.48-4.08-7.076-6.975l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
              ></path>
            </svg>
            <span
              class="group-hover:text-white transition-colors duration-300 cursor-default flex flex-col gap-1"
            >
              <span>652-629833</span>
              <span>+569-46894273</span>
            </span>
          </li>

          <!-- Correo -->
          <li class="flex items-start gap-3 group">
            <svg
              class="w-5 h-5 mt-0.5 text-[#C90203] opacity-80 group-hover:opacity-100 transition-opacity flex-shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
              ></path>
            </svg>
            <span
              class="group-hover:text-white transition-colors duration-300 cursor-default flex flex-col gap-1"
            >
              <span>colegiocharlesdarwindeancud@gmail.com</span>
              <span>utpdarwindeancud@gmail.com</span>
            </span>
          </li>
        </ul>
      </div>

      <!-- ─── SECCIÓN 4: REDES SOCIALES ────────────────── -->
      <div class="lg:col-span-2 flex flex-col items-center md:items-start">
        <h3 class="trykker-subtitle mb-6 tracking-wide" style="color: #FCFCFC;">
          Síguenos
        </h3>
        <div class="flex items-center gap-3">
          <!-- Instagram -->
          <a
            href="https://www.instagram.com/darwindeancud/?hl=es-la"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="w-10 h-10 rounded-full flex items-center justify-center bg-white/5 border border-white/10 text-white transition-all duration-300 hover:bg-[#C90203] hover:border-[#C90203] hover:scale-110 hover:shadow-[0_0_15px_rgba(201,2,3,0.5)]"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              class="w-5 h-5"
              xmlns="http://www.w3.org/2000/svg"
            >
              <rect
                x="2"
                y="2"
                width="20"
                height="20"
                rx="5"
                stroke="currentColor"
                stroke-width="1.8"></rect>
              <circle
                cx="12"
                cy="12"
                r="4.5"
                stroke="currentColor"
                stroke-width="1.8"></circle>
              <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor"></circle>
            </svg>
          </a>

          <!-- Facebook -->
          <a
            href="https://web.facebook.com/people/Colegio-Charles-Darwin-de-Ancud/100057382873989/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="w-10 h-10 rounded-full flex items-center justify-center bg-white/5 border border-white/10 text-white transition-all duration-300 hover:bg-[#C90203] hover:border-[#C90203] hover:scale-110 hover:shadow-[0_0_15px_rgba(201,2,3,0.5)]"
          >
            <svg
              viewBox="0 0 24 24"
              fill="currentColor"
              class="w-5 h-5"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"
              ></path>
            </svg>
          </a>

          <!-- YouTube -->
          <a
            href="https://www.youtube.com/@charlesdarwinancud7620/videos"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="YouTube"
            class="w-10 h-10 rounded-full flex items-center justify-center bg-white/5 border border-white/10 text-white transition-all duration-300 hover:bg-[#C90203] hover:border-[#C90203] hover:scale-110 hover:shadow-[0_0_15px_rgba(201,2,3,0.5)]"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              class="w-5 h-5"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 001.46 6.42 29 29 0 001 12a29 29 0 00.46 5.58 2.78 2.78 0 001.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.96A29 29 0 0023 12a29 29 0 00-.46-5.58z"
                stroke="currentColor"
                stroke-width="1.8"></path>
              <polygon
                points="9.75,15.02 15.5,12 9.75,8.98 9.75,15.02"
                fill="currentColor"></polygon>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════ -->
    <!-- PARTE INFERIOR: COPYRIGHT                          -->
    <!-- ══════════════════════════════════════════════════ -->

    <!-- Separador sutil -->
    <div
      class="w-full h-px bg-gradient-to-r from-transparent via-white/10 to-transparent mb-8"
    >
    </div>

    <div
      class="trykker-small flex flex-col md:flex-row items-center justify-between gap-4"
      style="color: rgba(252,252,252,0.5);"
    >
      <p
        class="text-center md:text-left transition-colors duration-300 hover:text-white/80 cursor-default"
      >
        © {currentYear} Colegio Charles Darwin. Todos los derechos reservados.
      </p>

      <div class="flex items-center gap-6">
        <span
          class="hover:text-white transition-colors duration-300 cursor-default"
          >Políticas de Privacidad</span
        >
        <span
          class="hover:text-white transition-colors duration-300 cursor-default"
          >Términos de Uso</span
        >
      </div>
    </div>
  </div>
</footer>
